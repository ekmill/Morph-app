<body class="bg-gradient-to-br from-purple-50 via-pink-50 to-blue-50 min-h-screen">
    
    <!-- Header -->
   <header class="bg-white shadow-lg">
        <div class="container mx-auto px-4 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 rounded-full flex items-center justify-center text-white text-2xl">
                        🔍
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800 kid-font">Word Detective AI</h1>
                        <p class="text-sm text-gray-600">Discover the Magic of Words!</p>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-right">
                        <p class="text-sm text-gray-600">Student: <span class="font-semibold">Emma</span></p>
                        <p class="text-xs text-gray-500">Grade 3 • 🏆 12 Badges</p>
                    </div>
                    <img src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=100&amp;h=100&amp;fit=crop" alt="Student avatar" class="w-12 h-12 rounded-full border-2 border-purple-500">
                </div>
            </div>
        </div>
    </header>

    <!-- Progress Bar -->
    <div class="bg-white border-b border-gray-200">
        <div class="container mx-auto px-4 py-4">
            <div class="flex items-center justify-between" id="progressBar">
                <div class="progress-step flex-1 text-center py-3 rounded-lg mx-1 transition-all active">
                    <i class="fas fa-search text-xl mb-1"></i>
                    <p class="text-xs font-semibold">1. Investigate</p>
                </div>
                <div class="progress-step flex-1 text-center py-3 rounded-lg mx-1 bg-gray-100 text-gray-600 transition-all">
                    <i class="fas fa-puzzle-piece text-xl mb-1"></i>
                    <p class="text-xs font-semibold">2. Analyze</p>
                </div>
                <div class="progress-step flex-1 text-center py-3 rounded-lg mx-1 bg-gray-100 text-gray-600 transition-all">
                    <i class="fas fa-tree text-xl mb-1"></i>
                    <p class="text-xs font-semibold">3. Etymology</p>
                </div>
                <div class="progress-step flex-1 text-center py-3 rounded-lg mx-1 bg-gray-100 text-gray-600 transition-all">
                    <i class="fas fa-flask text-xl mb-1"></i>
                    <p class="text-xs font-semibold">4. Test</p>
                </div>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-4 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Main Content Area -->
            <div class="lg:col-span-2">

                
                <!-- Step 1: Word investigation -->
                <section id="step1" class="bg-white rounded-2xl shadow-xl p-6 mb-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-2xl font-bold text-gray-800 kid-font flex items-center">
                            <span class="text-3xl mr-3">🔍</span>
                            shit 1: Choose Your Word
                        </h2>
                        <span class="bg-purple-100 text-purple-700 px-3 py-1 rounded-full text-sm font-semibold">Active</span>
                    </div>
                    
                    <div class="mb-6">
                        <label class="block text-gray-700 font-semibold mb-2">What word do you want to investigate?</label>
                        <div class="flex space-x-2">
                            <input type="text" id="wordInput" placeholder="Type a word (e.g., 'unhappiness')" class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-purple-500 focus:outline-none text-lg">
                            <button onclick="investigateWord()" class="bg-gradient-to-r from-purple-500 to-pink-500 text-white px-6 py-3 rounded-lg font-semibold hover:shadow-lg transition-all">
                                Investigate!
                            </button>
                        </div>
                    </div>
                    
                    <div class="mb-6">
                        <p class="text-gray-700 font-semibold mb-3">Or pick a word from your reading:</p>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                            <div class="word-card bg-gradient-to-br from-blue-100 to-blue-200 p-4 rounded-lg shadow" onclick="selectWord('unhappiness')">
                                <p class="text-lg font-bold text-blue-800">unhappiness</p>
                                <p class="text-xs text-blue-600">from your story</p>
                            </div>
                            <div class="word-card bg-gradient-to-br from-green-100 to-green-200 p-4 rounded-lg shadow" onclick="selectWord('discover')">
                                <p class="text-lg font-bold text-green-800">discover</p>
                                <p class="text-xs text-green-600">from science book</p>
                            </div>
                            <div class="word-card bg-gradient-to-br from-yellow-100 to-yellow-200 p-4 rounded-lg shadow" onclick="selectWord('wonderful')">
                                <p class="text-lg font-bold text-yellow-800">wonderful</p>
                                <p class="text-xs text-yellow-600">from poem</p>
                            </div>
                            <div class="word-card bg-gradient-to-br from-red-100 to-red-200 p-4 rounded-lg shadow" onclick="selectWord('bicycle')">
                                <p class="text-lg font-bold text-red-800">bicycle</p>
                                <p class="text-xs text-red-600">from journal</p>
                            </div>
                            <div class="word-card bg-gradient-to-br from-purple-100 to-purple-200 p-4 rounded-lg shadow" onclick="selectWord('television')">
                                <p class="text-lg font-bold text-purple-800">television</p>
                                <p class="text-xs text-purple-600">from history</p>
                            </div>
                            <div class="word-card bg-gradient-to-br from-pink-100 to-pink-200 p-4 rounded-lg shadow" onclick="selectWord('rebuild')">
                                <p class="text-lg font-bold text-pink-800">rebuild</p>
                                <p class="text-xs text-pink-600">from math word problem</p>
                            </div>
                        </div>
                    </div>
                    
                    <div id="wordMeaning" class="hidden bg-gradient-to-r from-purple-50 to-pink-50 p-4 rounded-lg border-2 border-purple-200">
                        <h3 class="font-bold text-purple-800 mb-2">📖 What does it mean?</h3>
                        <p id="meaningText" class="text-gray-700"></p>
                    </div>
                </section>

                <!-- Step 2: Morphological Analysis -->
                <section id="step2" class="bg-white rounded-2xl shadow-xl p-6 mb-6 hidden">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-2xl font-bold text-gray-800 kid-font flex items-center">
                            <span class="text-3xl mr-3">🧩</span>
                            Step 2: Break It Apart!
                        </h2>
                        <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold">Active</span>
                    </div>
                    
                    <div class="mb-6">
                        <h3 class="text-lg font-bold text-gray-800 mb-3">Word Sum Builder</h3>
                        <p class="text-gray-600 mb-4">Drag and drop morphemes to build your word!</p>
                        
                        <div class="bg-gray-50 p-6 rounded-lg mb-4">
                            <div class="text-center mb-4">
                                <p class="text-sm text-gray-600 mb-2">Available Morphemes:</p>
                                <div id="morphemeBank" class="flex flex-wrap justify-center">
                                    <!-- Will be populated by JavaScript -->
                                </div>
                            </div>
                            
                            <div class="bg-white p-6 rounded-lg border-2 border-dashed border-gray-300 min-h-24 flex items-center justify-center">
                                <div id="wordSum" class="text-2xl font-bold flex items-center flex-wrap justify-center">
                                    <span class="text-gray-400">Drop morphemes here...</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="flex justify-center space-x-3">
                            <button onclick="checkWordSum()" class="bg-gradient-to-r from-green-500 to-blue-500 text-white px-6 py-3 rounded-lg font-semibold hover:shadow-lg transition-all">
                                ✓ Check My Answer
                            </button>
                            <button onclick="resetWordSum()" class="bg-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-400 transition-all">
                                ↻ Reset
                            </button>
                        </div>
                    </div>
                    
                    <div id="morphologyFeedback" class="hidden mb-6"></div>
                    
                    <div class="mb-6">
                        <h3 class="text-lg font-bold text-gray-800 mb-3">Morphological Matrix</h3>
                        <p class="text-gray-600 mb-4">See all the words in the same family!</p>
                        
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse" id="morphMatrix">
                                <!-- Will be populated by JavaScript -->
                            </table>
                        </div>
                    </div>
                </section>

                <!-- Step 3: Etymology -->
                <section id="step3" class="bg-white rounded-2xl shadow-xl p-6 mb-6 hidden">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-2xl font-bold text-gray-800 kid-font flex items-center">
                            <span class="text-3xl mr-3">🌳</span>
                            Step 3: Word History Tree
                        </h2>
                        <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full text-sm font-semibold">Active</span>
                    </div>
                    
                    <div class="mb-6">
                        <p class="text-gray-700 mb-4">Every word has a story! Let's trace where your word came from:</p>
                        
                        <div id="etymologyTree" class="bg-gradient-to-br from-green-50 to-blue-50 p-6 rounded-lg">
                            <!-- Will be populated by JavaScript -->
                        </div>
                    </div>
                    
                    <div class="bg-yellow-50 border-2 border-yellow-300 rounded-lg p-4">
                        <h4 class="font-bold text-yellow-800 mb-2">🎓 Cool Fact!</h4>
                        <p id="etymologyFact" class="text-gray-700"></p>
                    </div>
                </section>


                <!-- Step 4: Hypothesis Testing -->
                <section id="step5" class="bg-white rounded-2xl shadow-xl p-6 mb-6 hidden">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-2xl font-bold text-gray-800 kid-font flex items-center">
                            <span class="text-3xl mr-3">🔬</span>
                            Step 4: Test Your Ideas!
                        </h2>
                        <span class="bg-pink-100 text-pink-700 px-3 py-1 rounded-full text-sm font-semibold">Active</span>
                    </div>
                    
                    <div class="mb-6">
                        <p class="text-gray-700 mb-4">Scientists test their ideas - so do word detectives! Let's test spelling rules:</p>
                        
                        <div class="hypothesis-card">
                            <h4 class="font-bold text-gray-800 mb-3">🤔 Your Hypothesis:</h4>
                            <p class="text-gray-700 mb-4 italic" id="hypothesisStatement"></p>
                            
                            <div class="mb-4">
                                <h5 class="font-semibold text-gray-800 mb-2">Test it with these words:</h5>
                                <div id="testWords" class="grid grid-cols-2 md:grid-cols-3 gap-3">
                                    <!-- Will be populated by JavaScript -->
                                </div>
                            </div>
                            
                            <div class="bg-green-50 border-2 border-green-300 rounded-lg p-4">
                                <h5 class="font-bold text-green-800 mb-2">✅ Results:</h5>
                                <p id="hypothesisResults" class="text-gray-700"></p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="text-center">
                        <button onclick="completeInquiry()" class="bg-gradient-to-r from-pink-500 to-purple-500 text-white px-8 py-4 rounded-lg font-bold text-lg hover:shadow-xl transition-all">
                            🎉 Complete Word Investigation!
                        </button>
                    </div>
                </section>

            </div>

            <!-- AI Guide Sidebar -->
            <div class="lg:col-span-1">
                <div class="sticky top-4">
                    
                    <!-- AI Guide -->
                    <div class="ai-bubble mb-6">
                        <div class="pt-4">
                            <h3 class="font-bold text-gray-800 mb-2 kid-font text-lg">Your AI Guide</h3>
                            <p id="aiGuidance" class="text-gray-700 text-sm leading-relaxed">
                                Hi Emma! 👋 I'm here to help you become a word detective! Pick a word that interests you, and we'll discover its secrets together. What word would you like to investigate today?
                            </p>
                        </div>
                        
                        <div class="mt-4 pt-4 border-t border-gray-300">
                            <p class="text-xs text-gray-600 mb-2">💬 Need help?</p>
                            <button onclick="askAI()" class="w-full bg-white text-purple-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-purple-50 transition-all">
                                Ask AI Guide
                            </button>
                        </div>
                    </div>
                    
                    <!-- Progress Tracker -->
                    <div class="bg-white rounded-2xl shadow-xl p-6 mb-6">
                        <h3 class="font-bold text-gray-800 mb-4 kid-font text-lg flex items-center">
                            <span class="mr-2">📊</span> Your Progress
                        </h3>
                        
                        <div class="space-y-3">
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-gray-600">Words Investigated</span>
                                    <span class="font-bold text-purple-700">23</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-gradient-to-r from-purple-500 to-pink-500 h-2 rounded-full" style="width: 46%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-gray-600">Morphemes Mastered</span>
                                    <span class="font-bold text-green-700">45</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-gradient-to-r from-green-500 to-blue-500 h-2 rounded-full" style="width: 75%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between text-sm mb-1">
                                    <span class="text-gray-600">This Week's Goal</span>
                                    <span class="font-bold text-blue-700">8/10</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-2 rounded-full" style="width: 80%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Badges -->
                    <div class="bg-white rounded-2xl shadow-xl p-6">
                        <h3 class="font-bold text-gray-800 mb-4 kid-font text-lg flex items-center">
                            <span class="mr-2">🏆</span> Recent Badges
                        </h3>
                        
                        <div class="grid grid-cols-3 gap-3">
                            <div class="text-center">
                                <div class="text-4xl mb-1">🌟</div>
                                <p class="text-xs text-gray-600">Word Explorer</p>
                            </div>
                            <div class="text-center">
                                <div class="text-4xl mb-1">🧩</div>
                                <p class="text-xs text-gray-600">Morpheme Master</p>
                            </div>
                            <div class="text-center">
                                <div class="text-4xl mb-1">🌳</div>
                                <p class="text-xs text-gray-600">Etymology Expert</p>
                            </div>
                            <div class="text-center opacity-50">
                                <div class="text-4xl mb-1">🔊</div>
                                <p class="text-xs text-gray-600">Sound Sleuth</p>
                            </div>
                            <div class="text-center opacity-50">
                                <div class="text-4xl mb-1">🔬</div>
                                <p class="text-xs text-gray-600">Hypothesis Hero</p>
                            </div>
                            <div class="text-center opacity-50">
                                <div class="text-4xl mb-1">👑</div>
                                <p class="text-xs text-gray-600">Word Detective</p>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </div> 

    <!-- Success Modal -->
    <div id="successModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-8 max-w-md mx-4 text-center">
            <div class="text-6xl mb-4">🎉</div>
