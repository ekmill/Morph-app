<html lang="en"><head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI-Guided Structured Word Inquiry - Interactive Prototype</title>
    <meta name="description" content="An interactive prototype demonstrating AI-assisted Structured Word Inquiry (SWI) for K-5 literacy education, featuring morphological analysis, etymology exploration, and adaptive learning.">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Fredoka:wght@400;600&display=swap');
        
        body {
            font-family: 'Poppins', sans-serif;
        }
        
        .kid-font {
            font-family: 'Fredoka', sans-serif;
        }
        
        .morpheme-base {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            display: inline-block;
            margin: 0.25rem;
            font-weight: 600;
        }
        
        .morpheme-prefix {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            display: inline-block;
            margin: 0.25rem;
            font-weight: 600;
        }
        
        .morpheme-suffix {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            display: inline-block;
            margin: 0.25rem;
            font-weight: 600;
        }
        
        .ai-bubble {
            background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .ai-bubble::before {
            content: '🤖';
            position: absolute;
            top: -1rem;
            left: 1rem;
            font-size: 2rem;
        }
        
        .word-card {
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .word-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }
        
        .progress-step {
            position: relative;
        }
        
        .progress-step.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .progress-step.completed {
            background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
            color: white;
        }
        
        .tree-node {
            background: #f3f4f6;
            border: 2px solid #667eea;
            border-radius: 0.5rem;
            padding: 0.75rem;
            margin: 0.5rem;
            display: inline-block;
        }
        
        .tree-line {
            border-left: 2px solid #667eea;
            height: 2rem;
            margin-left: 2rem;
        }
        
        .grapheme-box {
            border: 3px solid #4facfe;
            border-radius: 0.5rem;
            padding: 1rem;
            margin: 0.5rem;
            display: inline-block;
            min-width: 3rem;
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .phoneme-box {
            background: #fef3c7;
            border: 2px dashed #f59e0b;
            border-radius: 0.5rem;
            padding: 0.5rem;
            margin: 0.5rem;
            display: inline-block;
            min-width: 3rem;
            text-align: center;
        }
        
        .hypothesis-card {
            background: white;
            border: 2px solid #e5e7eb;
            border-radius: 1rem;
            padding: 1.5rem;
            margin: 1rem 0;
        }
        
        .badge-earned {
            animation: bounce 0.5s ease;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }
        
        .matrix-cell {
            border: 2px solid #d1d5db;
            padding: 0.75rem;
            text-align: center;
            background: white;
            transition: all 0.3s ease;
        }
        
        .matrix-cell:hover {
            background: #f3f4f6;
            border-color: #667eea;
        }
        
        .matrix-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            font-weight: bold;
            padding: 0.75rem;
            text-align: center;
        }
    </style>
