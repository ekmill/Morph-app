// Initialize
document.addEventListener('DOMContentLoaded', function() {
    console.log('Word Detective AI initialized');
    updateProgressBar();
});

// Word Investigation Functions
function selectWord(word) {
    document.getElementById('wordInput').value = word;
    investigateWord();
}

function investigateWord() {
    const input = document.getElementById('wordInput').value.trim().toLowerCase();
    
    if (!input) {
        alert('Please enter a word!');
        return;
    }
    
    if (!wordData[input]) {
        alert('Let\'s try a different word! Pick one from the cards below.');
        return;
    }
    
    currentWord = input;
    currentStep = 1;
    
    // Show meaning
    const meaningDiv = document.getElementById('wordMeaning');
    const meaningText = document.getElementById('meaningText');
    meaningText.textContent = wordData[input].meaning;
    meaningDiv.classList.remove('hidden');
    
    // Update AI guidance
    updateAIGuidance('Great choice! I see you picked "' + input + '". Now let\'s break it into parts. Click the button below when you\'re ready!');
    
    // Show next step button
    setTimeout(() => {
        if (confirm('Ready to analyze "' + input + '" and break it into morphemes?')) {
            goToStep(2);
        }
    }, 2000);
}

// Step Navigation
function goToStep(step) {
    currentStep = step;
    
    // Hide all steps
    for (let i = 1; i <= 5; i++) {
        document.getElementById('step' + i).classList.add('hidden');
    }
    
    // Show current step
    document.getElementById('step' + step).classList.remove('hidden');
    
    // Update progress bar
    updateProgressBar();
    
    // Load step content
    switch(step) {
        case 2:
            loadMorphologyStep();
            break;
        case 3:
            loadEtymologyStep();
            break;
        case 4:
            loadGraphemePhonemeStep();
            break;
        case 5:
            loadHypothesisStep();
            break;
    }
    
    // Scroll to top
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function updateProgressBar() {
    const steps = document.querySelectorAll('.progress-step');
    steps.forEach((step, index) => {
        step.classList.remove('active', 'completed');
        if (index + 1 < currentStep) {
            step.classList.add('completed');
        } else if (index + 1 === currentStep) {
            step.classList.add('active');
        }
    });
}

// Step 2: Morphology
function loadMorphologyStep() {
    const data = wordData[currentWord];
    
    // Load morpheme bank
    const bank = document.getElementById('morphemeBank');
    bank.innerHTML = '';
    
    if (data.morphemes.prefix.length > 0) {
        data.morphemes.prefix.forEach(m => {
            bank.innerHTML += `<span class="morpheme-prefix cursor-move" draggable="true" ondragstart="drag(event)">${m}</span>`;
        });
    }
    
    data.morphemes.base.forEach(m => {
        bank.innerHTML += `<span class="morpheme-base cursor-move" draggable="true" ondragstart="drag(event)">${m}</span>`;
    });
    
    if (data.morphemes.suffix.length > 0) {
        data.morphemes.suffix.forEach(m => {
            bank.innerHTML += `<span class="morpheme-suffix cursor-move" draggable="true" ondragstart="drag(event)">${m}</span>`;
        });
    }
    
    // Setup drop zone
    const dropZone = document.getElementById('wordSum');
    dropZone.innerHTML = '<span class="text-gray-400">Drop morphemes here...</span>';
    dropZone.ondrop = drop;
    dropZone.ondragover = allowDrop;
    
    // Load matrix
    loadMorphMatrix();
    
    updateAIGuidance('Excellent! Now drag the morphemes to build your word. Remember: prefixes come first, then the base, then suffixes. The colors will help you! 🎨');
}

function drag(ev) {
    ev.dataTransfer.setData("text", ev.target.textContent);
    ev.dataTransfer.setData("class", ev.target.className);
}

function allowDrop(ev) {
    ev.preventDefault();
}

function drop(ev) {
    ev.preventDefault();
    const text = ev.dataTransfer.getData("text");
    const className = ev.dataTransfer.getData("class");
    
    const dropZone = document.getElementById('wordSum');
    if (dropZone.querySelector('.text-gray-400')) {
        dropZone.innerHTML = '';
    }
    
    const span = document.createElement('span');
    span.className = className;
    span.textContent = text;
    dropZone.appendChild(span);
    
    if (selectedMorphemes.length > 0) {
        const plus = document.createElement('span');
        plus.className = 'text-2xl mx-2';
        plus.textContent = '+';
        dropZone.insertBefore(plus, span);
    }
    
    selectedMorphemes.push(text);
}

function resetWordSum() {
    selectedMorphemes = [];
    const dropZone = document.getElementById('wordSum');
    dropZone.innerHTML = '<span class="text-gray-400">Drop morphemes here...</span>';
    document.getElementById('morphologyFeedback').classList.add('hidden');
}

function checkWordSum() {
    const data = wordData[currentWord];
    const correct = [...data.morphemes.prefix, ...data.morphemes.base, ...data.morphemes.suffix];
    
    const feedback = document.getElementById('morphologyFeedback');
    
    if (JSON.stringify(selectedMorphemes) === JSON.stringify(correct)) {
        feedback.className = 'bg-green-100 border-2 border-green-500 rounded-lg p-4 mb-6';
        feedback.innerHTML = `
            <h4 class="font-bold text-green-800 mb-2">🎉 Perfect! You got it!</h4>
            <p class="text-gray-700 mb-3">The word sum is: <strong>${data.wordSum}</strong></p>
            <button onclick="goToStep(3)" class="bg-gradient-to-r from-green-500 to-blue-500 text-white px-6 py-3 rounded-lg font-semibold hover:shadow-lg transition-all">
                Continue to Etymology →
            </button>
        `;
        feedback.classList.remove('hidden');
        
        updateAIGuidance('Fantastic work! You correctly identified all the morphemes. Now let\'s explore where this word came from! 🌳');
    } else {
        feedback.className = 'bg-yellow-100 border-2 border-yellow-500 rounded-lg p-4 mb-6';
        feedback.innerHTML = `
            <h4 class="font-bold text-yellow-800 mb-2">🤔 Not quite right...</h4>
            <p class="text-gray-700">Try again! Remember the order: prefix + base + suffix</p>
        `;
        feedback.classList.remove('hidden');
        
        updateAIGuidance('That\'s okay! Learning takes practice. Remember: prefixes go first, then the base word, then suffixes. Try dragging them in a different order! 💪');
    }
}

function loadMorphMatrix() {
    const data = wordData[currentWord];
    const matrix = document.getElementById('morphMatrix');
    
    let html = '<thead><tr>';
    html += '<th class="matrix-header">Base: ' + data.matrix.base + '</th>';
    data.matrix.suffixes.forEach(suffix => {
        html += '<th class="matrix-header">+ ' + suffix + '</th>';
    });
    html += '</tr></thead><tbody>';
    
    // Add prefix rows
    if (data.matrix.prefixes.length > 0) {
        data.matrix.prefixes.forEach(prefix => {
            html += '<tr>';
            html += '<td class="matrix-cell font-bold">' + prefix + ' +</td>';
            data.matrix.suffixes.forEach(() => {
                html += '<td class="matrix-cell">...</td>';
            });
            html += '</tr>';
        });
    }
    
    // Add related words rows
    data.matrix.related.forEach(row => {
        html += '<tr>';
        row.forEach(word => {
            html += '<td class="matrix-cell">' + word + '</td>';
        });
        html += '</tr>';
    });
    
    html += '</tbody>';
    matrix.innerHTML = html;
}

// Step 3: Etymology
function loadEtymologyStep() {
    const data = wordData[currentWord];
    const tree = document.getElementById('etymologyTree');
    
    let html = '<div class="text-center mb-6">';
    html += '<div class="tree-node text-xl font-bold">' + data.etymology.modern + '</div>';
    html += '</div>';
    
    data.etymology.stages.forEach(stage => {
        html += '<div class="tree-line"></div>';
        html += '<div class="text-center mb-4">';
        html += '<div class="tree-node">';
        html += '<div class="font-bold text-lg">' + stage.word + '</div>';
        html += '<div class="text-sm text-gray-600">' + stage.language + '</div>';
        html += '<div class="text-xs text-gray-500 mt-1">' + stage.note + '</div>';
        html += '</div>';
        html += '</div>';
    });
    
    tree.innerHTML = html;
    
    document.getElementById('etymologyFact').textContent = data.etymology.fact;
    
    updateAIGuidance('Wow! Look at how old this word is! Words travel through time and across languages. Isn\'t that amazing? Ready to explore how we spell it? 🔤');
    
    setTimeout(() => {
        if (confirm('Ready to learn about the sounds and letters in "' + currentWord + '"?')) {
            goToStep(4);
        }
    }, 3000);
}

// Step 4: Grapheme-Phoneme
function loadGraphemePhonemeStep() {
    const data = wordData[currentWord];
    
    const graphemeDisplay = document.getElementById('graphemeDisplay');
    graphemeDisplay.innerHTML = '';
    data.graphemes.forEach(g => {
        graphemeDisplay.innerHTML += '<div class="grapheme-box">' + g + '</div>';
    });
    
    const phonemeDisplay = document.getElementById('phonemeDisplay');
    phonemeDisplay.innerHTML = '';
    data.phonemes.forEach(p => {
        phonemeDisplay.innerHTML += '<div class="phoneme-box">' + p + '</div>';
    });
    
    document.getElementById('spellingExplanation').textContent = data.spellingRule;
    
    updateAIGuidance('See how each letter or letter combination makes a sound? This is why English spelling makes sense when you understand the patterns! 🎵');
    
    setTimeout(() => {
        if (confirm('Ready to test your hypothesis about spelling rules?')) {
            goToStep(5);
        }
    }, 3000);
}

function playWordAudio() {
    updateAIGuidance('🔊 Listening to words helps you connect sounds to letters! (In a real app, you would hear the word pronounced here.)');
    alert('🔊 In the real application, you would hear "' + currentWord + '" pronounced clearly!');
}

// Step 5: Hypothesis Testing
function loadHypothesisStep() {
    const data = wordData[currentWord];
    
    document.getElementById('hypothesisStatement').textContent = data.hypothesis;
    
    const testWords = document.getElementById('testWords');
    testWords.innerHTML = '';
    data.testWords.forEach(word => {
        testWords.innerHTML += `
            <div class="bg-blue-50 border-2 border-blue-300 rounded-lg p-3 text-center">
                <span class="font-semibold text-blue-800">${word}</span>
                <div class="mt-2">
                    <span class="text-2xl">✓</span>
                </div>
            </div>
        `;
    });
    
    document.getElementById('hypothesisResults').textContent = 
        'Your hypothesis is correct! All these words follow the same spelling pattern. You\'re becoming a real word detective! 🔍';
    
    updateAIGuidance('Excellent scientific thinking! Testing hypotheses is exactly what real linguists do. You\'ve mastered the complete word inquiry process! 🎓');
}

function completeInquiry() {
    document.getElementById('successModal').classList.remove('hidden');
    updateAIGuidance('🎉 Congratulations! You\'ve completed a full Structured Word Inquiry! You\'ve earned the Word Detective badge. Ready to investigate another word?');
}

