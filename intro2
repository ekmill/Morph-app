}

// AI Guide Functions
function updateAIGuidance(message) {
    const guidance = document.getElementById('aiGuidance');
    guidance.style.opacity = '0';
    setTimeout(() => {
        guidance.textContent = message;
        guidance.style.opacity = '1';
    }, 300);
}

function askAI() {
    const messages = [
        'I\'m here to help! What would you like to know? 😊',
        'Great question! Remember, every word has a story. Let\'s discover it together! 📖',
        'You\'re doing great! Keep exploring and asking questions! 🌟',
        'Need a hint? Try looking at the colors - they show you different types of morphemes! 🎨'
    ];
    const randomMessage = messages[Math.floor(Math.random() * messages.length)];
    updateAIGuidance(randomMessage);
}
